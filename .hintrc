{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": "off",
    "axe/forms": [
      "default",
      {
        "select-name": "off"
      }
    ],
    "no-inline-styles": "off",
    "button-type": "off",
    "axe/keyboard": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 112",
    "not ios_saf <= 26.2",
    "not safari <= 26.2",
    "not samsung <= 29",
    "not chrome <= 116",
    "not ios_saf <= 26.3",
    "not safari <= 26.3"
  ]
}